DirectoryIndex index.php

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.houseandhomesintoronto\.com$ [NC]
RewriteRule ^(.*)$ https://houseandhomesintoronto.com/$1 [R=301,L]

# Trailing slash for directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ $1/ [R=301,L]

# Clean URLs: try .php extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# Block access to sensitive files
<FilesMatch "\.(env|log|gitignore)$">
    Require all denied
</FilesMatch>

# Block access to lib directory (not meant for public)
<IfModule mod_rewrite.c>
    RewriteRule ^lib/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^tmp/ - [F,L]
</IfModule>
